PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://xitamin.co.in
LEADS_FILE=storage/leads.jsonl
NEWSLETTER_FILE=storage/newsletter.jsonl

# Mailing
MAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="Xitamin Website <no-reply@xitamin.co.in>"
MAIL_TO=connect@xitamin.co.in
MAIL_REPLY_TO=connect@xitamin.co.in
MAIL_SEND_AUTO_REPLY=true
